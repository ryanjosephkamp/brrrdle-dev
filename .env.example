# Public Supabase browser configuration.
# These values are safe to expose in the client bundle when they are the project URL
# and public anon key. Never place service-role keys in VITE_* variables.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Server-side aliases used by Vercel functions such as /api/admin-refresh.
# Use the same public URL and anon key. Do not use service-role credentials here.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Shared secret used to authorize Vercel Cron invocations of
# /api/cron/refresh-word-lists. Generate a long random string. Vercel
# automatically attaches this value as `Authorization: Bearer <CRON_SECRET>`
# on scheduled requests when configured in the project's environment.
CRON_SECRET=replace-with-a-long-random-string

# Vercel Blob read/write token used by the production word-list persistence
# layer. When set, /api/cron/refresh-word-lists and /api/admin-refresh
# atomically swap the served word-list manifest in Vercel Blob storage.
# When unset, the refresh pipeline still validates upstream files but
# persistence is skipped and the existing bundled seed remains the served
# source. Obtain this token from the Vercel project's Blob store settings
# and configure it identically in production, preview, and (optionally)
# development environments.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace-with-token
